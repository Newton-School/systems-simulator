            "sawtooth": {
              "peakRps": 220,
              "rampDuration": 10000
            }
          }
        }
      }
    },
    {
      "id": "api",
      "type": "computeNode",
      "position": {
        "x": 680,
        "y": 260
      },
      "data": {
        "schemaVersion": 2,
        "templateId": "backend-server",
        "componentType": "microservice",
        "structuralRole": "processor",
        "profile": "compute-service",
        "rendererType": "computeNode",
        "label": "API Server",
        "subLabel": "Monolith Process",
        "iconKey": "SERVER",
        "sim": {
          "queue": {
            "workers": 8,
            "capacity": 40,
            "discipline": "fifo"
          },
          "processing": {
            "distribution": {
              "type": "constant",
              "value": 6
            },
            "timeout": 300
          }
        }
      }
    },
    {
