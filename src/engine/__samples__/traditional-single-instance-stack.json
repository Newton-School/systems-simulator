        "profile": "datastore",
        "rendererType": "serviceNode",
        "label": "Primary DB",
        "subLabel": "Disk / Query Execution",
        "iconKey": "database",
        "sim": {
          "queue": {
            "workers": 4,
            "capacity": 32,
            "discipline": "fifo"
          },
          "processing": {
            "distribution": {
              "type": "log-normal",
              "mu": 2.6,
              "sigma": 0.55
            },
            "timeout": 500
          }
        }
      }
