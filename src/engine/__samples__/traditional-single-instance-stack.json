      "target": "primary-db",
      "sourceHandle": "right-1-source",
      "targetHandle": "left-1-target",
      "animated": true,
      "data": {
        "protocol": "tcp",
        "mode": "synchronous",
        "latencyMu": 1.8,
        "latencySigma": 0.4,
        "bandwidth": 1000,
        "maxConcurrentRequests": 120,
        "packetLossRate": 0,
        "errorRate": 0
