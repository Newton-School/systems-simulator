{
  "name": "ns-simulator",
  "version": "1.0.0",
  "description": "A system design simulator with browser and Electron targets",
  "main": "./out/main/index.js",
  "author": "example.com",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dev": "vite",
    "dev:web": "vite",
    "dev:electron": "electron-vite dev",
    "build": "npm run typecheck && vite build",
    "build:web": "npm run typecheck && vite build",
    "build:electron": "npm run typecheck && electron-vite build",
    "build:electron:unpack": "npm run build:electron && electron-builder --dir",
    "build:electron:win": "npm run build:electron && electron-builder --win",
    "build:electron:mac": "electron-vite build && electron-builder --mac",
    "build:electron:linux": "electron-vite build && electron-builder --linux",
    "preview": "vite preview",
    "start:electron": "electron-vite preview",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "vitest run --root .",
    "test:perf": "RUN_PERF_TESTS=true vitest run --root .",
    "simulate": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.562.0",
    "react-resizable-panels": "^3.0.6",
    "reactflow": "^11.11.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.23",
    "electron": "^38.1.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.6",
    "vitest": "^4.1.0"
  }
}
